# Dev: delete this line or leave empty to use Vite proxy → http://127.0.0.1:4001 (see vite.config.ts).
# If you set a URL, use the API origin only — do NOT add /api (paths already include /api/...).
# If you use http://127.0.0.1:4001/api, exports break with "Endpoint not found."
# VITE_ADMIN_API_URL=http://127.0.0.1:4001
# Optional — maintenance “API health” tile pings this origin (default http://localhost:4011)
VITE_BUS_ATTENDANT_API_URL=http://localhost:4011

# WeatherAPI.com — copy key to .env.local (never commit real keys)
VITE_WEATHERAPI_KEY=

# Google Maps JavaScript API key (required for native Traffic/Transit/Bicycling layers in Locations map)
VITE_GOOGLE_MAPS_API_KEY=

# Passenger web app (Track Bus on admin marketing landing opens this origin — passenger landing is /)
VITE_PASSENGER_APP_URL=http://localhost:5174

# Firebase Web App (Project settings → Your apps → SDK setup)
# Copy to .env.local and fill values (never commit .env.local)
VITE_FIREBASE_API_KEY=
# Auth domain is derived as <VITE_FIREBASE_PROJECT_ID>.firebaseapp.com (do not set a second domain unless you use a Firebase custom auth domain in Console).
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
# Same Firebase project — Realtime Database (client listeners for live map / broadcasts).
# Must match the URL in Firebase Console (regional example — BusTracker / Singapore):
# VITE_FIREBASE_DATABASE_URL=https://bustracker-2966b-default-rtdb.asia-southeast1.firebasedatabase.app
