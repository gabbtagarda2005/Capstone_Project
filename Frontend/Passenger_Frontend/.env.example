# Passenger API (Backend/Passenger_Backend). In dev, Vite also proxies /api → http://127.0.0.1:4000 (see vite.config.ts), and the app tries same-origin first.
# Use the server root only — not .../api — or requests become /api/api/public/... and Admin returns "Endpoint not found."
VITE_PASSENGER_API_URL=http://localhost:4000

# Optional direct Admin URL if you do not use the passenger proxy (must allow CORS from the passenger web origin).
VITE_ADMIN_API_URL=http://localhost:4001

# Optional — weather tiles/advisories if the UI reads this key (not used by Admin_Backend).
# VITE_WEATHERAPI_KEY=
