# Passenger API (Node server in Backend/Passenger_Backend). When set, the app uses it for fare quote, fleet, map points, live board, and live GPS (proxied to Admin — set ADMIN_BACKEND_URL on the passenger server).
VITE_PASSENGER_API_URL=http://localhost:4000

# Optional direct Admin URL if you do not use the passenger proxy (must allow CORS from the passenger web origin).
VITE_ADMIN_API_URL=http://localhost:4001
