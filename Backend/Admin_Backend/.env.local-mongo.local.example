# Copy this file to `.env.local-mongo.local`, then run:
# npm run env:use:localmongo

# Local MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/CapstoneProject

JWT_SECRET=replace-with-long-random-secret
JWT_EXPIRES_IN=8h
PORT=4001
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
ADMIN_FRONTEND_URL=http://localhost:5173

# Firebase (optional if your setup uses it)
# GOOGLE_APPLICATION_CREDENTIALS=./secrets/your-service-account.json
# FIREBASE_DATABASE_URL=https://your-project-default-rtdb.asia-southeast1.firebasedatabase.app

# Mail / OTP (optional)
# OTP_DEV_REVEAL=false
# SMTP_SERVICE=gmail
# SMTP_USER=your_sender@gmail.com
# SMTP_PASS=your_gmail_app_password
# MAIL_FROM=your_sender@gmail.com
