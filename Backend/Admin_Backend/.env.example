# =============================================================================
# Two databases (both can be active at once)
# -----------------------------------------------------------------------------
# MONGODB_URI — Primary store: MongoDB Atlas (recommended) or local mongod.
#   Fleet + GPS, Socket.io, and (when MYSQL_* is unset) admin login collection portal_users.
#
# MYSQL_* — Ticketing + admin login via table `bus_operators` when ALL MYSQL_* are set.
#   If MYSQL_* is OMITTED: admin + operator login use MongoDB collection `portal_users`
#   (see scripts/seed-admin-mongo.js). Dashboard features that need SQL (operators CRUD,
#   tickets, locations) stay disabled until you add MySQL.
#
# Atlas URI: put your database name in the path, e.g. ...mongodb.net/bukidnon_transport?...
# If the DB password has @ # etc., URL-encode it in the connection string.
#
# querySrv ECONNREFUSED on Windows: public DNS is applied automatically (see config/mongoDns.js).
# Set ATLAS_USE_PUBLIC_DNS=0 to disable. If it still fails, use Atlas "standard" mongodb:// URI.
# =============================================================================

# MongoDB Atlas (fleet / GPS) — example:
# MONGODB_URI=mongodb+srv://USER:URL_ENCODED_PASSWORD@cluster0.xxxxx.mongodb.net/bukidnon_transport?retryWrites=true&w=majority&appName=Cluster0
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/bukidnon_transport?retryWrites=true&w=majority

# MySQL — bus operators, tickets, login_logs, locations (admin portal login)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=bus_ticketing

# JWT for admin portal sessions
JWT_SECRET=replace-with-long-random-string
JWT_EXPIRES_IN=8h

# HTTP + Socket.io
PORT=4001

# Comma-separated allowed origins (admin-portal, passenger-web)
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Base URL for password-reset links (simulated email in non-production)
ADMIN_FRONTEND_URL=http://localhost:5173

# Set to "true" to include resetLink in forgot-password JSON in production (not recommended)
# EXPOSE_RESET_LINK=false

# LilyGo / device ingest (set a strong random string in production)
DEVICE_INGEST_SECRET=

# Optional: Firebase Admin SDK JSON path for verifying ID tokens
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# How often the proximity worker ticks (ms) — placeholder until geofence logic is added
PROXIMITY_TICK_MS=15000
