# =============================================================================
# MongoDB Atlas (or local mongod) is the only database.
# -----------------------------------------------------------------------------
# MONGODB_URI — Fleet, GPS, portal_users (admin + attendants), ticketing (issued_ticket_records),
# ticket_locations, and all other app data.
#
# Atlas URI: put your database name in the path, e.g. ...mongodb.net/CapstoneProject?...
# If the DB password has @ # etc., URL-encode it in the connection string.
#
# querySrv ECONNREFUSED on Windows: public DNS is applied automatically (see config/mongoDns.js).
# Set ATLAS_USE_PUBLIC_DNS=0 to disable. If it still fails, use Atlas "standard" mongodb:// URI.
# =============================================================================

# MongoDB Atlas (fleet / GPS) — example:
# MONGODB_URI=mongodb+srv://USER:URL_ENCODED_PASSWORD@cluster0.xxxxx.mongodb.net/CapstoneProject?retryWrites=true&w=majority&appName=Cluster0
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/CapstoneProject?retryWrites=true&w=majority

# Optional: RouteCoverage ObjectIds in main-line order (overrides auto hub order below).
# If unset and fare_global_settings.hubChainCoverageIds is empty, the fare engine infers
# Don Carlos → Maramag → Valencia → Malaybalay from Location Management names and sums matrix legs (e.g. DC→MLY = 3 rows).
# FARE_HUB_CHAIN_COVERAGE_IDS=

# JWT for admin portal sessions
JWT_SECRET=replace-with-long-random-string
JWT_EXPIRES_IN=8h

# HTTP + Socket.io
PORT=4001

# Comma-separated allowed origins (admin-portal, passenger-web). Include 127.0.0.1 if you use that host.
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174

# Flutter web / random localhost ports: also allow http(s)://localhost:* and 127.0.0.1:* (set false in production if you lock origins)
# CORS_ALLOW_LOCALHOST=true

# Base URL for password-reset links (simulated email in non-production)
ADMIN_FRONTEND_URL=http://localhost:5173

# Set to "true" to include resetLink in forgot-password JSON in production (not recommended)
# EXPOSE_RESET_LINK=false

# LilyGo / device ingest (set a strong random string in production)
DEVICE_INGEST_SECRET=

# Firebase Admin — path to service account JSON (Google login on API)
# GOOGLE_APPLICATION_CREDENTIALS=./secrets/your-project-firebase-adminsdk.json
#
# Realtime Database URL (Console → Realtime Database → Data — copy the URL shown at top).
# Enables hybrid "twin-write": MongoDB remains source of truth; coverage + corridor routes
# mirror to Firebase for low-latency driver / tablet clients (live_map/*, current_routes/*).
# New projects often use a regional host, e.g. Singapore:
#   https://YOUR-PROJECT-default-rtdb.asia-southeast1.firebasedatabase.app
# Older US default DBs may still show: https://YOUR-PROJECT-default-rtdb.firebaseio.com
# FIREBASE_DATABASE_URL=

# Or inline service account (no JSON file):
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Password recovery OTP (Nodemailer). Without mail env, OTP is not emailed.
#
# Gmail (recommended): 2-Step Verification + App Password → paste as SMTP_PASS (not your normal password).
# OTP_DEV_REVEAL=true — shows OTP in login modal when email is not configured (dev only; set false after mail works).
# OTP_DEV_REVEAL=false
# SMTP_SERVICE=gmail
# SMTP_USER=you@gmail.com
# SMTP_PASS=xxxx-xxxx-xxxx-xxxx
# MAIL_FROM=you@gmail.com
#
# SendGrid: create API key; verify sender; MAIL_FROM must be verified.
# SENDGRID_API_KEY=SG.xxx
# MAIL_FROM=verified@example.com
#
# Generic SMTP (Outlook, etc.):
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@outlook.com
# SMTP_PASS=
# MAIL_FROM=you@outlook.com

# How often the proximity worker ticks (ms) — placeholder until geofence logic is added
PROXIMITY_TICK_MS=15000

# -----------------------------------------------------------------------------
# Automated daily operational log (cron + email + JSON/PDF snapshots + retries)
# -----------------------------------------------------------------------------
# Same data as GET /api/reports/daily-operations for *calendar yesterday* in DAILY_OPS_REPORT_TZ.
# Email: Section A (terminal geofence vs schedule), Section B (speed >80 km/h), dark HTML layout.
# Snapshots: YYYY-MM-DD_BUKIDNON_OPS.json and .pdf (slug overridable). Admin UI: Reports → Archive.
#
# DAILY_OPS_REPORT_CRON_ENABLED=true
# DAILY_OPS_REPORT_EMAIL_TO=ops@example.com,manager@example.com
# DAILY_OPS_REPORT_SNAPSHOT_DIR=./data/daily-ops-snapshots
# DAILY_OPS_REPORT_SNAPSHOT_SLUG=BUKIDNON_OPS
# DAILY_OPS_REPORT_CRON=30 6 * * *
# DAILY_OPS_REPORT_TZ=Asia/Manila
# DAILY_OPS_REPORT_BRAND=Bukidnon Bus Company
# Optional: public URL for email header logo (else placeholder glyph)
# DAILY_OPS_REPORT_LOGO_URL=https://your-cdn.example/logo.png
# If SMTP fails (e.g. rural connectivity), retry same send every N minutes until success or max attempts.
# DAILY_OPS_EMAIL_RETRY_MINUTES=30
# DAILY_OPS_EMAIL_MAX_RETRIES=48
#
# Requires mail env as OTP (SENDGRID_API_KEY or SMTP_* + MAIL_FROM).

# Master report export (POST /api/reports/master-export) — optional PDF branding
# REPORTS_LOGO_PATH=./assets/report-logo.png
# COMPANY_DISPLAY_NAME=Bukidnon Bus Company
# REPORTS_PDF_FOOTER=© 2026 Bukidnon Bus Company — Fleet Management Division

# -----------------------------------------------------------------------------
# IPROG SMS (Philippines) — ticket confirmations + attendant SOS to admin mobile
# https://www.iprogsms.com/api/v1/documentation
# -----------------------------------------------------------------------------
# Required for outbound SMS:
# IPROG_API_TOKEN=your_api_token_from_iprogsms_dashboard
# Optional: approved sender name from dashboard (sent as sender_name if supported by your account).
# IPROG_SENDER_NAME=BUKIDNON TRANSIT
# Override API path only if IPROG changes endpoints (default: .../sms_messages).
# IPROG_SMS_API_URL=https://www.iprogsms.com/api/v1/sms_messages
# Optional provider index 0–2 (see IPROG docs).
# IPROG_SMS_PROVIDER=0
#
# SOS: extra SMS destinations (tried before Admin → Settings company phone). Use comma or ; for several numbers.
# All of these are merged (not “first wins”): IPROG_SOS_TO, SOS_SMS_TO, TWILIO_SOS_TO.
# IPROG_SOS_TO=09171234567,+639915774040
# IPROG_SENDER_NAME must be an approved name from the IPROG dashboard (omit or leave unset if unsure).

# Driver OTP wizard (optional): comma-separated allowed email domains, e.g. gmail.com,buksu.edu.ph
# If unset, any valid email may be used (still must not duplicate driver / operator / portal user).
# DRIVER_SIGNUP_EMAIL_DOMAINS=gmail.com
# DRIVER_SIGNUP_JWT_EXPIRES_IN=20m
