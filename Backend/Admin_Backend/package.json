{
  "name": "admin-api",
  "version": "0.1.0",
  "private": true,
  "description": "Admin brain: fleet, GPS ingest, geofence proximity, Socket.io live map",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "migrate:capstone": "node scripts/migrate-mongodb-to-capstone.js",
    "migrate:capstone:drop": "node scripts/migrate-mongodb-to-capstone.js --drop-source",
    "migrate:capstone:fresh": "node scripts/migrate-mongodb-to-capstone.js --clear-target --drop-source"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "firebase-admin": "^13.0.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.8.0",
    "mysql2": "^3.11.0",
    "nodemailer": "^6.9.16",
    "socket.io": "^4.8.0"
  }
}
