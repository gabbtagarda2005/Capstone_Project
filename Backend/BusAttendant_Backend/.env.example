BUS_ATTENDANT_PORT=4011
BUS_ATTENDANT_JWT_SECRET=change-this-secret

# Where THIS process reaches Admin_Backend (ticketing, profile, maintenance are proxied here).
# Local: http://127.0.0.1:4001
# Deployed: https://your-admin-api.example.com  (no trailing slash)
# Admin_Backend uses MONGODB_URI in ITS .env for Atlas — this URL is only the HTTP bridge to that API.
ADMIN_BACKEND_URL=http://127.0.0.1:4001

# Admin must use the same JWT_SECRET when minting operator-login tokens (ticketingToken).

# Flutter / web clients use --dart-define=API_BASE_URL=http://HOST:4011 to reach THIS server.
# "Cannot reach localhost:4011" means BusAttendant_Backend is not running on that host/port, or the
# app is on a phone/emulator (use your PC LAN IP instead of localhost).

VITE_WEATHERAPI_KEY=c12fa43745954f43b9d164856260304