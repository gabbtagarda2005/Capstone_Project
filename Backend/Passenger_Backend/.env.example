# MongoDB Atlas connection string (replace user, password, cluster)
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/CapstoneProject?retryWrites=true&w=majority

# API port (change if 4000 is already in use — match VITE_PASSENGER_API_URL in the passenger web app)
PORT=4000

# Admin API base for proxying /api/public/* and /api/buses/live (fare quote, fleet, map points, live board, passenger feedback)
ADMIN_BACKEND_URL=http://localhost:4001

# Comma-separated origins for CORS + Socket.io (* for local dev only)
CORS_ORIGIN=http://localhost:5174,http://localhost:5173,http://localhost:3000
